ENVIRONMENT=dev

HTTP_ADDRESS=:8080
GRACEFUL_TIMEOUT=5s

# IP of your reverse proxy (e.g. 10.0.0.2) to trust X-Forwarded-For.
# Leave empty to disable proxy trust.
TRUSTED_PROXY=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=postgres
# Enable TLS for PostgreSQL connection (required in production with managed DBs)
POSTGRES_TLS=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Enable TLS for Redis/Valkey connection
REDIS_TLS=false
PASTE_CACHE_TTL=1h

# Required — create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret
GITHUB_REDIRECT_URL=http://localhost:8080/auth/redirect

ENABLE_PREFORK=false

CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_URL=